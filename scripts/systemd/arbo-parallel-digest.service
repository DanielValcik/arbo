[Unit]
Description=Arbo PARALLEL daily digest (morning briefing)
After=network-online.target postgresql.service arbo.service

[Service]
Type=oneshot
User=arbo
Group=arbo
WorkingDirectory=/opt/arbo
EnvironmentFile=/opt/arbo/.env
ExecStart=/opt/arbo/.venv/bin/python /opt/arbo/scripts/parallel_digest.py
StandardOutput=journal
StandardError=journal
TimeoutStartSec=300
